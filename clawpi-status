#!/usr/bin/env bash
# clawpi-status - Set border indicator state
#
# Usage:
#   clawpi-status <state>
#
# States: idle, thinking, responding, tool_use, disconnected
#
# Examples:
#   clawpi-status idle
#   clawpi-status thinking
#   clawpi-status responding
#   clawpi-status tool_use
#   clawpi-status disconnected

STATUS_FILE="/tmp/clawpi-status"
TMP_FILE="/tmp/clawpi-status.tmp"

VALID_STATES="idle thinking responding tool_use disconnected"

STATE="$1"

if [ -z "$STATE" ]; then
    echo "Usage: clawpi-status <state>"
    echo "States: $VALID_STATES"
    exit 1
fi

# Validate state
valid=false
for s in $VALID_STATES; do
    if [ "$STATE" = "$s" ]; then
        valid=true
        break
    fi
done

if [ "$valid" = false ]; then
    echo "Invalid state: $STATE"
    echo "Valid states: $VALID_STATES"
    exit 1
fi

# Atomic write via rename to reliably trigger inotify watchers
echo "$STATE" > "$TMP_FILE"
mv -f "$TMP_FILE" "$STATUS_FILE"
echo "State: $STATE"
