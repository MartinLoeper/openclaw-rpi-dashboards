;; ClawPi status overlay widgets
(defvar clawpi_state "idle")
(defvar clawpi_tool_name "")
(defvar clawpi_message "")
(defvar clawpi_tts_playing false)

(defwidget status-indicator []
  (box :class "status-container status-${clawpi_state}"
       :visible {clawpi_state != "idle"}
       :space-evenly false
    (label :class "status-icon"
           :text {clawpi_state == "transcribing" ? "🎙" :
                  clawpi_state == "thinking" ? "🧠" :
                  clawpi_state == "tool_use" ? "🔧" :
                  clawpi_state == "responding" ? "💬" :
                  clawpi_state == "error" ? "⚠" :
                  clawpi_state == "disconnected" ? "🔌" : ""})
    (label :class "status-text"
           :text {clawpi_state == "transcribing" ? "Transcribing..." :
                  clawpi_state == "thinking" ? "Thinking..." :
                  clawpi_state == "tool_use" ? "Using: ${clawpi_tool_name}" :
                  clawpi_state == "responding" ? "Responding..." :
                  clawpi_state == "error" ? clawpi_message :
                  clawpi_state == "disconnected" ? "Reconnecting..." : ""})))

(defwidget tts-stop-button []
  (button :class "tts-stop-btn"
          :onclick "curl -sf -X POST http://localhost:3100/api/tts/stop || echo '[eww] tts stop curl failed (rc=$?)' >&2"
    (box :space-evenly false
      (label :class "tts-stop-icon" :text "⏹")
      (label :class "tts-stop-text" :text "Stop"))))

(defwindow status-overlay
  :monitor 0
  :geometry (geometry :x "10px"
                      :y "10px"
                      :width "300px"
                      :height "60px"
                      :anchor "top right")
  :stacking "overlay"
  :exclusive false
  :focusable false
  :namespace "clawpi-overlay"
  (status-indicator))

(defwindow tts-stop-overlay
  :monitor 0
  :geometry (geometry :x "10px"
                      :y "10px"
                      :width "120px"
                      :height "50px"
                      :anchor "bottom right")
  :stacking "overlay"
  :exclusive false
  :focusable true
  :namespace "clawpi-tts-stop"
  (tts-stop-button))
